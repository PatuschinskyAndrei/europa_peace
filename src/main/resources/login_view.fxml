<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.europapeace.controllers.LoginController"
           style="-fx-background-color: #2c3e50;">

    <VBox spacing="20" alignment="CENTER" maxWidth="350" maxHeight="500"
          style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);">

        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <Text text="EUROPA PEACE" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-fill: #34495e;"/>
        <Text text="Autentificare" style="-fx-font-size: 14; -fx-fill: #7f8c8d;"/>

        <VBox spacing="5">
            <Label text="Utilizator:"/>
            <TextField fx:id="txtUsername" promptText="username" style="-fx-background-radius: 10; -fx-padding: 10;"/>
        </VBox>

        <VBox spacing="5">
            <Label text="Parolă:"/>
            <PasswordField fx:id="txtPassword" promptText="password" style="-fx-background-radius: 10; -fx-padding: 10;"/>
        </VBox>

        <Button text="LOG IN" onAction="#handleLogin" prefWidth="Infinity"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12;"/>

        <Separator />

        <Label fx:id="lblMessage" text="" style="-fx-font-weight: bold;"/>
    </VBox>
</StackPane>