<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:id="mainBorderPane"
            fx:controller="com.example.europapeace.controllers.MapController"
            prefHeight="850.0" prefWidth="1300.0" style="-fx-background-color: #add8e6;">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" prefHeight="65.0" style="-fx-background-color: #2c3e50;">
            <padding><Insets left="20" right="20"/></padding>
            <Text text="EUROPA PEACE" style="-fx-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Zona de Profil actualizată -->
            <HBox alignment="CENTER_RIGHT" spacing="15">
                <VBox alignment="CENTER_RIGHT">
                    <Label fx:id="lblNumeUtilizator" text="User" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Label fx:id="lblRolUtilizator" text="Role" style="-fx-text-fill: #bdc3c7; -fx-font-size: 11;"/>
                </VBox>

                <!-- Bulina de profil cu meniu dropdown -->
                <MenuButton fx:id="menuProfil" mnemonicParsing="false"
                            style="-fx-background-color: #34495e; -fx-background-radius: 50; -fx-min-width: 45; -fx-min-height: 45; -fx-max-width: 45; -fx-max-height: 45; -fx-cursor: hand;">
                    <graphic>
                        <Label text="👤" style="-fx-text-fill: white; -fx-font-size: 18;"/>
                    </graphic>
                    <items>
                        <SeparatorMenuItem />
                        <MenuItem text="Log Out" onAction="#handleLogout" style="-fx-text-fill: #c0392b; -fx-font-weight: bold;" />
                    </items>
                </MenuButton>
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox fx:id="meniuStanga" spacing="15" prefWidth="240" style="-fx-background-color: white;">
            <padding><Insets top="30" right="15" bottom="20" left="15"/></padding>

            <Button text="Mod Unire State" onAction="#pornesteModUnire" prefWidth="Infinity"/>

            <Separator />

            <Label fx:id="lblInstructiuni" text="Așteptare comenzi..." wrapText="true" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <VBox fx:id="vboxUnire" spacing="10" managed="false" visible="false">
                <TextField fx:id="txtRegiuneSursa" promptText="Tastează sau dă click pe sursă..." editable="true" style="-fx-background-color: #ffffff; -fx-border-color: #bdc3c7;"/>
                <TextField fx:id="txtRegiuneDestinatie" promptText="Nume regiune țară nouă..." style="-fx-background-color: #ffffff; -fx-border-color: #bdc3c7;"/>

                <HBox spacing="5">
                    <Button text="Confirmă" onAction="#handleConfirmareUnire" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="100"/>
                    <Button text="Anulează" onAction="#handleAnuleazaUnire" style="-fx-background-color: #c0392b; -fx-text-fill: white;" prefWidth="100"/>
                </HBox>
            </VBox>

            <Button fx:id="btnAactiveazaUnire" text="Unire cu Stat" onAction="#handleUnire" prefWidth="Infinity" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>

            <Separator />
            <Button text="Independenta" onAction="#handleIndependenta" prefWidth="Infinity" />

            <Button text="Gestionează Cereri" onAction="#handleGestioneazaCereri" prefWidth="Infinity" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"/>

            <Button text="Reset Hartă" onAction="#resetHarta" prefWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <ScrollPane fx:id="scrollPane" fitToHeight="true" fitToWidth="true" style="-fx-background-color: #add8e6;">
            <content>
                <Pane fx:id="mapPane" prefWidth="5000" prefHeight="4000" style="-fx-background-color: #add8e6;" />
            </content>
        </ScrollPane>
    </center>
</BorderPane>